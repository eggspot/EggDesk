<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpotDesk.UI.ViewModels"
        xmlns:views="using:SpotDesk.UI.Views"
        xmlns:controls="using:SpotDesk.UI.Controls"
        xmlns:local="using:SpotDesk.UI.Views"
        x:Class="SpotDesk.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SpotDesk"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="40">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+K" Command="{Binding OpenSearchCommand}"/>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewConnectionCommand}"/>
    <KeyBinding Gesture="Ctrl+OemBackslash" Command="{Binding ToggleSidebarCommand}"/>
    <KeyBinding Gesture="Ctrl+W" Command="{Binding ActiveTab.CloseCommand}"/>
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ActiveTab.ReconnectCommand}"/>
    <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding ForceSyncCommand}"/>
    <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchToTab1Command}"/>
    <KeyBinding Gesture="Ctrl+D2" Command="{Binding SwitchToTab2Command}"/>
    <KeyBinding Gesture="Ctrl+D3" Command="{Binding SwitchToTab3Command}"/>
    <KeyBinding Gesture="Ctrl+D4" Command="{Binding SwitchToTab4Command}"/>
    <KeyBinding Gesture="Ctrl+D5" Command="{Binding SwitchToTab5Command}"/>
    <KeyBinding Gesture="Ctrl+D6" Command="{Binding SwitchToTab6Command}"/>
    <KeyBinding Gesture="Ctrl+D7" Command="{Binding SwitchToTab7Command}"/>
    <KeyBinding Gesture="Ctrl+D8" Command="{Binding SwitchToTab8Command}"/>
    <KeyBinding Gesture="Ctrl+D9" Command="{Binding SwitchToTab9Command}"/>
  </Window.KeyBindings>

  <Grid RowDefinitions="40,*">

    <!-- TAB BAR / TITLE BAR (40px) — drag region for window move -->
    <Border Grid.Row="0"
            x:Name="TitleBar"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
    <Grid ColumnDefinitions="Auto,*,Auto">

      <!-- Sidebar toggle + app name -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="12,0">
        <Button Classes="ghost-button" Command="{Binding ToggleSidebarCommand}"
                ToolTip.Tip="Toggle sidebar (Ctrl+\)">
          <TextBlock Text="≡" FontSize="16"/>
        </Button>
        <TextBlock Text="SpotDesk" FontSize="14" FontWeight="Medium"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Tab strip -->
      <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal">
          <Button Classes="ghost-button" Command="{Binding NewConnectionCommand}"
                  Margin="4,0" ToolTip.Tip="New connection (Ctrl+N)">
            <TextBlock Text="+ New" FontSize="13"/>
          </Button>
          <ItemsControl ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SessionTabViewModel">
                <controls:SessionTab/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <!-- App buttons + window chrome -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch" Spacing="0" Margin="4,0,0,0">
        <Button Classes="ghost-button" Command="{Binding ForceSyncCommand}"
                ToolTip.Tip="Sync vault (Ctrl+Shift+S)" Margin="0,0,4,0">
          <TextBlock Text="↑" FontSize="14"/>
        </Button>
        <Button Classes="ghost-button" Command="{Binding OpenSettingsCommand}"
                ToolTip.Tip="Settings (Ctrl+,)" Margin="0,0,8,0">
          <TextBlock Text="⚙" FontSize="14"/>
        </Button>

        <!-- Separator -->
        <Border Width="1" Margin="0,8" Background="{DynamicResource BorderSubtleBrush}"/>

        <!-- Min / Max / Close -->
        <Button x:Name="MinimizeButton"
                Width="46" Height="40"
                Background="Transparent" BorderThickness="0"
                ToolTip.Tip="Minimize">
          <TextBlock Text="&#x2212;" FontSize="14" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Button>
        <Button x:Name="MaximizeButton"
                Width="46" Height="40"
                Background="Transparent" BorderThickness="0"
                ToolTip.Tip="Maximize / Restore">
          <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" FontSize="11"
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Button>
        <Button x:Name="CloseButton"
                Width="46" Height="40"
                Background="Transparent" BorderThickness="0"
                ToolTip.Tip="Close">
          <TextBlock Text="&#x2715;" FontSize="13" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Button>
      </StackPanel>
    </Grid>
    </Border>

    <!-- CONTENT AREA -->
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

      <!-- SIDEBAR -->
      <Border Grid.Column="0"
              Width="{Binding IsSidebarVisible, Converter={StaticResource SidebarWidthConverter}}"
              Background="{DynamicResource BgSurfaceBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}"
              BorderThickness="0,0,1,0"
              IsVisible="{Binding IsSidebarVisible}">
        <views:SidebarView DataContext="{Binding ConnectionTree}"/>
      </Border>

      <!-- SESSION PANE -->
      <Grid Grid.Column="1" Background="{DynamicResource BgBaseBrush}">
        <views:WelcomeView IsVisible="{Binding IsWelcomeVisible}"/>
        <!-- Active session view rendered by SessionTabView -->
        <ContentControl Content="{Binding ActiveTab}"
                        IsVisible="{Binding !IsWelcomeVisible}">
          <ContentControl.ContentTemplate>
            <local:SessionViewSelector/>
          </ContentControl.ContentTemplate>
        </ContentControl>
      </Grid>
    </Grid>
  </Grid>

</Window>
