<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:SpotDesk.Core.Models"
             x:Class="SpotDesk.UI.Controls.ConnectionListItem"
             x:DataType="models:ConnectionEntry">

  <Grid ColumnDefinitions="24,*,Auto,Auto" Height="40"
        Background="Transparent" Cursor="Hand">
    <Grid.Styles>
      <Style Selector="Grid:pointerover">
        <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
      </Style>
    </Grid.Styles>

    <!-- Status dot -->
    <Ellipse Grid.Column="0" Width="8" Height="8"
             Fill="{DynamicResource StatusIdleBrush}"
             VerticalAlignment="Center"
             Margin="8,0,0,0"/>

    <!-- Name + host -->
    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
      <TextBlock Text="{Binding Name}" FontSize="14"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 TextTrimming="CharacterEllipsis"/>
      <TextBlock Text="{Binding Host}" FontSize="11"
                 Foreground="{DynamicResource TextTertiaryBrush}"
                 FontFamily="{DynamicResource FontMono}"/>
    </StackPanel>

    <!-- Protocol badge -->
    <Border Grid.Column="2" Classes="protocol-badge" Margin="4,0">
      <TextBlock Text="{Binding Protocol}" FontSize="11"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 FontFamily="{DynamicResource FontMono}"/>
    </Border>

    <!-- Connect button (visible on hover) -->
    <Button Grid.Column="3" Content="Connect" FontSize="12"
            Classes="primary-button" Margin="4,0" Padding="8,4"
            Opacity="0">
      <Button.Styles>
        <Style Selector="Grid:pointerover Button">
          <Setter Property="Opacity" Value="1"/>
        </Style>
      </Button.Styles>
    </Button>
  </Grid>

</UserControl>
