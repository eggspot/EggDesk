<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpotDesk.UI.Dialogs.CredentialEditorDialog"
        Title="Edit Credential"
        Width="480" Height="380"
        Background="{DynamicResource BgBaseBrush}"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="56,*,64">

    <Border Grid.Row="0"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,0">
      <TextBlock Text="{Binding Title}"
                 FontSize="16" FontWeight="Medium"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 VerticalAlignment="Center"/>
    </Border>

    <ScrollViewer Grid.Row="1" Padding="24">
      <StackPanel Spacing="16">

        <StackPanel Spacing="6">
          <TextBlock Text="Display name" FontSize="12"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <TextBox x:Name="NameBox" Watermark="e.g. alice-prod"/>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="Username" FontSize="12"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <TextBox x:Name="UsernameBox" Watermark="username"/>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="Password" FontSize="12"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <TextBox x:Name="PasswordBox" PasswordChar="•" Watermark="password"/>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="SSH key path (optional)" FontSize="12"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" x:Name="SshKeyBox"
                     Watermark="~/.ssh/id_ed25519"/>
            <Button  Grid.Column="1" Content="Browse…" Classes="ghost-button"
                     Click="OnBrowseSshKey"/>
          </Grid>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="24,0">
      <StackPanel Orientation="Horizontal" Spacing="8"
                  HorizontalAlignment="Right" VerticalAlignment="Center">
        <Button Content="Cancel" Classes="ghost-button" Click="OnCancel"/>
        <Button Content="Save"   Classes="primary-button" Click="OnSave"/>
      </StackPanel>
    </Border>

  </Grid>
</Window>
