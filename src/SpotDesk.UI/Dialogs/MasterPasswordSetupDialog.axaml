<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpotDesk.UI.Dialogs.MasterPasswordSetupDialog"
        Title="Set Master Password"
        Width="440" Height="320"
        Background="{DynamicResource BgBaseBrush}"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="56,*,64">

    <Border Grid.Row="0"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,0">
      <TextBlock Text="Set Master Password"
                 FontSize="16" FontWeight="Medium"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 VerticalAlignment="Center"/>
    </Border>

    <ScrollViewer Grid.Row="1" Padding="24">
      <StackPanel Spacing="16">
        <TextBlock TextWrapping="Wrap"
                   Text="A master password adds a second factor beyond device-key encryption. Optional but recommended for shared machines."
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <StackPanel Spacing="6">
          <TextBlock Text="New password" FontSize="12"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <TextBox x:Name="PasswordBox" PasswordChar="•" Watermark="Enter password"/>
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock Text="Confirm password" FontSize="12"
                     Foreground="{DynamicResource TextTertiaryBrush}"/>
          <TextBox x:Name="ConfirmBox" PasswordChar="•" Watermark="Re-enter password"/>
        </StackPanel>

        <TextBlock x:Name="ErrorLabel"
                   FontSize="12"
                   Foreground="{DynamicResource StatusErrorBrush}"
                   IsVisible="False"/>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="{DynamicResource BgSurfaceBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="24,0">
      <StackPanel Orientation="Horizontal" Spacing="8"
                  HorizontalAlignment="Right" VerticalAlignment="Center">
        <Button Content="Skip for now" Classes="ghost-button" Click="OnSkip"/>
        <Button Content="Set Password" Classes="primary-button" Click="OnSetPassword"/>
      </StackPanel>
    </Border>

  </Grid>
</Window>
