<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:SpotDesk.UI.Converters"
             x:Class="SpotDesk.UI.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    <StyleInclude Source="avares://SpotDesk.UI/Styles/DarkTheme.axaml"/>
    <StyleInclude Source="avares://SpotDesk.UI/Styles/Controls.axaml"/>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://SpotDesk.UI/Styles/ColorTokens.axaml"/>
      </ResourceDictionary.MergedDictionaries>

      <!-- Typography -->
      <FontFamily x:Key="FontSans">avares://SpotDesk.UI/Assets/Fonts#Inter,
          system-ui, -apple-system, sans-serif</FontFamily>
      <FontFamily x:Key="FontMono">avares://SpotDesk.UI/Assets/Fonts#JetBrains Mono,
          Consolas, monospace</FontFamily>

      <!-- Converters (StaticResource so XAML bindings can resolve them) -->
      <local:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter"/>
      <local:ActiveTabBorderConverter    x:Key="ActiveTabBorderConverter"/>
      <local:LatencyColorConverter       x:Key="LatencyColorConverter"/>
      <local:SidebarWidthConverter       x:Key="SidebarWidthConverter"/>
      <local:ExpandArrowConverter        x:Key="ExpandArrowConverter"/>
    </ResourceDictionary>
  </Application.Resources>

</Application>
